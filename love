<!DOCTYPE html>
<html lang="ja">

<head>
    <meta charset="UTF-8" />
    <title>Heart Axis UI</title>

    <style>
        :root {
            --hue: 0;
        }

        body {
            margin: 0;
            height: 100vh;
            display: grid;
            place-items: center;
            font-family: Arial, sans-serif;
            user-select: none;
            overflow: hidden;
            background:
                radial-gradient(1px 1px at 20% 30%, rgba(255, 255, 255, .8), transparent 40%),
                radial-gradient(1px 1px at 70% 60%, rgba(255, 255, 255, .6), transparent 40%),
                radial-gradient(1px 1px at 40% 80%, rgba(255, 255, 255, .7), transparent 40%),
                radial-gradient(1px 1px at 85% 20%, rgba(255, 255, 255, .5), transparent 40%),
                linear-gradient(to bottom, #0f2027, #203a43, #2c5364);
        }

        body::after {
            content: "";
            position: fixed;
            inset: 0;
            background: radial-gradient(circle at center, rgba(255, 255, 255, 0.35), transparent 60%);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.6s ease;
        }

        body.climax::after {
            opacity: 1;
        }

        .wrap {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 18px 26px;
            border-radius: 28px;
            background: rgba(255, 255, 255, 0.18);
            backdrop-filter: blur(6px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.18);
            animation: fadeIn 900ms ease-out both;
            text-align: center;
        }

        body.climax .wrap {
            box-shadow: 0 14px 45px rgba(255, 180, 220, 0.35);
            background: rgba(255, 255, 255, 0.24);
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(14px) scale(0.98);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .row {
            display: grid;
            grid-template-columns: 90px auto 90px;
            /* 左心固定 90，中间自适应，右心固定 90 */
            align-items: center;
            column-gap: 18px;
            height: 120px;
        }

        .title {
            font-size: 54px;
            font-family: "Georgia", "Times New Roman", serif;
            letter-spacing: 1.5px;
            margin: 0;
            line-height: 1.1;
            transform-origin: center;

            background: linear-gradient(45deg,
                    hsl(var(--hue), 100%, 72%),
                    hsl(calc(var(--hue) + 40), 100%, 60%));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;

            text-shadow:
                0 2px 10px rgba(255, 255, 255, 0.45),
                0 8px 22px rgba(255, 120, 150, 0.45);

            animation: textLoveFloat 1.4s ease-in-out infinite;
            will-change: transform, opacity;
        }

        @keyframes textLoveFloat {
            0% {
                transform: translateY(45px) scale(0.97);
                opacity: 0.85;
            }

            50% {
                transform: translateY(-35px) scale(1.05);
                opacity: 1;
            }

            100% {
                transform: translateY(45px) scale(0.97);
                opacity: 0.85;
            }
        }

        .subtitle {
            margin-top: 6px;
            font-family: "Georgia", serif;
            letter-spacing: 1px;
            font-size: 18px;
            color: rgba(255, 255, 255, 0.85);
            text-shadow: 0 6px 18px rgba(255, 120, 150, 0.35);
            animation: subGlow 2.2s ease-in-out infinite alternate;
        }

        @keyframes subGlow {
            from {
                opacity: 0.75;
                transform: translateY(0);
            }

            to {
                opacity: 1;
                transform: translateY(-2px);
            }
        }

        .heart {
            width: 90px;
            height: 90px;
            display: grid;
            place-items: center;
            filter: hue-rotate(calc(var(--hue) * 1deg));
            text-shadow: 0 8px 22px rgba(255, 120, 150, 0.35);
            transition: transform 0.4s ease;
            /* 让靠近更柔 */
        }

        .heart span {
            display: inline-block;
            font-size: 82px;
            will-change: transform;
        }

        .heart.left span {
            animation: heartPulseSlow 1.6s ease-in-out infinite;
             transform: translateX(2px)
        }

        .heart.right span {
            animation: heartPulseFast 1.1s ease-in-out infinite;
            transform: translateX(-1px);
        }

        @keyframes heartPulseSlow {

            0%,
            100% {
                transform: scale(1) translateY(6px);
            }

            50% {
                transform: scale(1.18) translateY(-10px);
            }
        }

        @keyframes heartPulseFast {

            0%,
            100% {
                transform: scale(1.05) translateY(-4px);
            }

            50% {
                transform: scale(1.28) translateY(10px);
            }
        }

        .climax .title {
            animation-play-state: paused;
            transform: translateY(-55px) scale(1.08);
        }

        .climax .heart span {
            animation: heartSync 0.9s ease-in-out 1;
        }

        @keyframes heartSync {
            0% {
                transform: scale(1);
            }

            40% {
                transform: scale(1.35);
            }

            70% {
                transform: scale(1.15);
            }

            100% {
                transform: scale(1);
            }
        }

        /* 高潮时：左右心轻微靠近 */
        .climax .heart.left {
            transform: translateX(4px);
        }

        .climax .heart.right {
            transform: translateX(-4px);
        }
    </style>
</head>

<body>
    <div class="wrap">
        <div class="row">
            <div class="heart left"><span>❤️</span></div>
            <h1 class="title">“I’ll love you forever.”</h1>
            <div class="heart right"><span>❤️</span></div>
        </div>
        <div class="subtitle">Will you marry me?</div>
    </div>

    <script>
        'use strict';

        const root = document.documentElement;

        let running = true;
        let rafId = null;
        let frozenHue = 0;

        function tick() {
            if (!running) return;

            const t = Date.now() / 1200;
            const baseHue = 300 + Math.sin(t) * 30; // 270~330（避开绿色）
            const leftHue = baseHue + 15; // 偏粉
            const rightHue = baseHue - 15; // 偏紫

            frozenHue = baseHue;
            root.style.setProperty('--hue', baseHue.toFixed(2));

            document.querySelector('.heart.left').style.filter = `hue-rotate(${leftHue}deg)`;
            document.querySelector('.heart.right').style.filter = `hue-rotate(${rightHue}deg)`;

            rafId = requestAnimationFrame(tick);
        }
        tick();

        // 高潮：统一颜色 + 同步 + 靠近
        setTimeout(() => {
            document.body.classList.add("climax");
            const unifyHue = frozenHue;
            document.querySelectorAll('.heart')
                .forEach(h => h.style.filter = `hue-rotate(${unifyHue}deg)`);
        }, 3000);

        // 高潮结束：颜色定格
        setTimeout(() => {
            document.body.classList.remove("climax");
            running = false;
            if (rafId) cancelAnimationFrame(rafId);
            root.style.setProperty('--hue', frozenHue.toFixed(2));
        }, 4600);

        // 收尾：全部停下 + 标题回正
        setTimeout(() => {
            // 停止心和副标题动画
            document.querySelectorAll('.heart span, .subtitle')
                .forEach(el => el.style.animationPlayState = 'paused');

            // 标题回正并停住
            const title = document.querySelector('.title');
            title.style.animationPlayState = 'paused';
            title.style.transform = 'translateY(0) scale(1)';

            // ❤️❤️ 最终定格：两颗心贴近
            const leftHeart = document.querySelector('.heart.left');
            const rightHeart = document.querySelector('.heart.right');

            leftHeart.style.transform = 'translateX(4px)';
            rightHeart.style.transform = 'translateX(-4px)';
        }, 5200);

    </script>
</body>

</html>
